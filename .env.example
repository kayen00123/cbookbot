# Twitter Login Credentials (for browser automation - NO PAID API NEEDED!)
# Your X.com username (phone number or @handle without @)
TWITTER_USERNAME=your_username_here
TWITTER_PASSWORD=your_password_here

# Gemini AI API Key (for generating tweet threads)
# Get your free API key from https://aistudio.google.com/app/apikey
# The free tier has generous limits for text generation
GEMINI_API_KEY=your_gemini_api_key_here

# Bot Settings
# Timezone for scheduling (e.g., America/New_York, UTC, Europe/London)
TIMEZONE=UTC

# Scheduled Tweet Times (24-hour format)
# Separate multiple times with commas
# Example: "09:00,12:00,15:00,18:00,21:00"
SCHEDULED_TIMES=09:00,12:00,15:00,18:00,21:00

# Separate time for hashtag engagement (24-hour format)
# Example: "14:30" - run hashtag engagement at 2:30 PM
HASHTAG_TIME=

# Separate time for account monitoring (24-hour format)
# Example: "13:15" - run account monitoring at 1:15 PM
# If not set, defaults to 9:00 AM and 9:00 PM
ACCOUNT_TIME=

# Tweet Content Settings
# Enable random tweet selection from queue
ENABLE_RANDOM_MODE=true

# Enable logging
LOG_LEVEL=info
